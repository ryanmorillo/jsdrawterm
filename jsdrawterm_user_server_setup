#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: ./jsdrawterm_user_server_setup [YOUR.SERVER] [options]

Options:
  --server HOST           Remote server hostname/IP (if not passed positionally)
  --http-port PORT        Local HTTP server port (default: 8000)
  --write-config          Write config.local.js based on options

Notes:
  - If config.local.js exists it is used, otherwise config.js.
  - Websockify is started only when needed and a server is provided.
USAGE
}

server=""
http_port=8000
write_config=0

if [[ $# -gt 0 && $1 != --* ]]; then
  server="$1"
  shift
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --server) server="$2"; shift 2;;
    --http-port) http_port="$2"; shift 2;;
    --write-config) write_config=1; shift;;
    -h|--help) usage; exit 0;;
    *) echo "Unknown option: $1"; usage; exit 1;;
  esac
done

config_file=""
if [[ -f  $HOME/.config/jsdrawterm.config ]]; then
  config_file="$HOME/.config/jsdrawterm.config"
elif [[ -f config.local.js ]]; then
  config_file="config.local.js"
elif [[ -f config.js ]]; then
  config_file="config.js"
fi

get_var() {
  local name="$1"
  local file="$2"
  local line
  if [[ -z $file ]]; then
    return
  fi
  line=$(grep -E "^var[[:space:]]+${name}[[:space:]]*=" "$file" 2>/dev/null | tail -n 1 || true)
  if [[ -z "$line" ]]; then
    echo "setting line for $name failed"
    return
  fi
  echo "$line" | sed -E "s/.*=[[:space:]]*//; s/[;[:space:]]*$//"
}

strip_quotes() {
  local v="$1"
  v="${v%\"}"
  v="${v#\"}"
  echo "$v"
}

has_config_url() {
  local url="$1"
  if [[ -z "$url" ]]; then
    return 1
  fi
  url=$(strip_quotes "$url")
  if [[ "$url" == "undefined" ]]; then
    return 1
  fi
  return 0
}

ws_port_from_url() {
  local url="$1"
  if ! has_config_url "$url"; then
    echo ""
    return
  fi
  url=$(strip_quotes "$url")
  if [[ "$url" != ws://localhost:* && "$url" != wss://localhost:* ]]; then
    echo ""
    return
  fi
  echo "$url" | sed -E 's#^[a-z]+://localhost:([0-9]+).*#\1#'
}

set_var_in_file() {
  local file="$1"
  local name="$2"
  local value="$3"
  if grep -Eq "^var[[:space:]]+${name}[[:space:]]*=" "$file"; then
    sed -i -E "s#^var[[:space:]]+${name}[[:space:]]*=.*#var ${name} = ${value};#" "$file"
  else
    echo "var ${name} = ${value};" >> "$file"
  fi
}

has_var_in_file() {
  local file="$1"
  local name="$2"
  grep -Eq "^var[[:space:]]+${name}[[:space:]]*=" "$file"
}

port_listening() {
  local port="$1"
  if command -v ss >/dev/null 2>&1; then
    ss -ltn "sport = :$port" | grep -q ":$port"
  elif command -v netstat >/dev/null 2>&1; then
    netstat -ltn 2>/dev/null | grep -q ":$port "
  else
    return 1
  fi
}

if [[ $write_config -eq 1 ]]; then
  python - <<'PY'
import re, pathlib
src = pathlib.Path('config.js')
if not src.exists():
    raise SystemExit('config.js not found')
lines = src.read_text().splitlines()
vars_wanted = ['rcpu_url','ncpu_url','auth_url','user','password','domain','dom']
found = {}
for line in lines:
    m = re.match(r"\\s*var\\s+(\\w+)\\s*=\\s*(.*?);\\s*$", line)
    if not m:
        continue
    name, val = m.group(1), m.group(2)
    if name in vars_wanted:
        found[name] = val
out = ['// Auto-generated from config.js']
for name in vars_wanted:
    if name in found:
        out.append(f"var {name} = {found[name]};")
path = pathlib.Path('config.local.js')
path.write_text("\\n".join(out) + "\\n")
print('Wrote config.local.js')
PY
  config_file="config.local.js"
fi

if [[ -n "$config_file" && "$config_file" != "config.local.js" ]]; then
  cp "$config_file" config.local.js
  config_file="config.local.js"
  echo "Using config.local.js copied from \$HOME/.config/jsdrawterm.config"
fi

if [[ -f config.local.js ]]; then
  # If user config does not define a domain, override config.js placeholders.
  if ! has_var_in_file config.local.js domain; then
    echo "var domain = undefined;" >> config.local.js
    echo "Set domain to undefined in config.local.js (use server-offered auth domain)"
  fi
  if ! has_var_in_file config.local.js dom; then
    echo "var dom = undefined;" >> config.local.js
  fi
fi

rcpu_url=$(get_var rcpu_url "$config_file")
ncpu_url=$(get_var ncpu_url "$config_file")
auth_url=$(get_var auth_url "$config_file")

rcpu_port=$(ws_port_from_url "$rcpu_url")
ncpu_port=$(ws_port_from_url "$ncpu_url")
auth_port=$(ws_port_from_url "$auth_url")

if [[ -z "$config_file" ]]; then
  echo "No config.local.js or config.js found. Using defaults." >&2
  rcpu_port=${rcpu_port:-1234}
  ncpu_port=${ncpu_port:-1236}
  auth_port=${auth_port:-1235}
fi

if ! has_config_url "$ncpu_url"; then
  echo "Warning: ncpu_url not set; new windows will fail." >&2
fi

if [[ -n "$server" && -f config.local.js ]]; then
  if has_config_url "$rcpu_url" && [[ -z "$rcpu_port" ]]; then
    rcpu_port=1234
    set_var_in_file config.local.js rcpu_url "\"ws://localhost:${rcpu_port}\""
    echo "Normalized rcpu_url to ws://localhost:${rcpu_port} (proxy to ${server}:17019)"
  fi
  if has_config_url "$ncpu_url" && [[ -z "$ncpu_port" ]]; then
    ncpu_port=1236
    set_var_in_file config.local.js ncpu_url "\"ws://localhost:${ncpu_port}\""
    echo "Normalized ncpu_url to ws://localhost:${ncpu_port} (proxy to ${server}:17010)"
  fi
  if has_config_url "$auth_url" && [[ -z "$auth_port" ]]; then
    auth_port=1235
    set_var_in_file config.local.js auth_url "\"ws://localhost:${auth_port}\""
    echo "Normalized auth_url to ws://localhost:${auth_port} (proxy to ${server}:567)"
  fi
fi

websockify_cmd=()
if command -v websockify >/dev/null 2>&1; then
  websockify_cmd=(websockify)
else
  echo "websockify not found in PATH." >&2
  exit 1
fi

pids=()
cleanup() {
  for pid in "${pids[@]}"; do
    kill "$pid" >/dev/null 2>&1 || true
  done
}
trap cleanup EXIT

start_proxy() {
  local local_port="$1"
  local remote_port="$2"
  if [[ -z "$local_port" ]]; then
    return
  fi
  if port_listening "$local_port"; then
    return
  fi
  if [[ -z "$server" ]]; then
    echo "Missing server for websockify. Run:" >&2
    echo "  websockify ${local_port} YOUR.SERVER:${remote_port}" >&2
    return
  fi
  echo "${websockify_cmd[*]} ${local_port} ${server}:${remote_port}"
  "${websockify_cmd[@]}" "$local_port" "$server":"$remote_port" &
  pids+=("$!")
}

start_proxy "$rcpu_port" 17019
if [[ -n "$rcpu_port" ]]; then
  echo "Started rcpu proxy on port $rcpu_port"
else
  echo "rcpu_url is not localhost; skipping local rcpu proxy setup."
fi
start_proxy "$ncpu_port" 17010
if [[ -n "$ncpu_port" ]]; then
  echo "Started ncpu proxy on port $ncpu_port"
else
  echo "ncpu_url is not localhost; skipping local ncpu proxy setup."
fi
if [[ -n "$auth_port" ]]; then
  start_proxy "$auth_port" 567
  echo "Started auth proxy"
else
  echo "auth_url is not localhost; skipping local auth proxy setup."
fi

python - <<PY
import http.server, socketserver
class H(http.server.SimpleHTTPRequestHandler):
    extensions_map = dict(http.server.SimpleHTTPRequestHandler.extensions_map)
    extensions_map['.wasm'] = 'application/wasm'
    def end_headers(self):
        self.send_header('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0')
        self.send_header('Pragma', 'no-cache')
        self.send_header('Expires', '0')
        super().end_headers()
with socketserver.TCPServer(('', ${http_port}), H) as httpd:
    print('HTTP server on port ${http_port}')
    httpd.serve_forever()
PY
